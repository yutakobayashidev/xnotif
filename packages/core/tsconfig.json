{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "types": ["bun"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/test-encrypt.ts"]
}
