{
  "name": "xnotif",
  "version": "0.1.0",
  "description": "Receive Twitter/X push notifications programmatically via Mozilla Autopush",
  "keywords": [
    "twitter",
    "x",
    "push",
    "notifications",
    "autopush",
    "webpush"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yutakobayashidev/reverse-twitter-notifications"
  },
  "homepage": "https://github.com/yutakobayashidev/reverse-twitter-notifications",
  "bugs": "https://github.com/yutakobayashidev/reverse-twitter-notifications/issues",
  "author": "yutakobayashidev",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --packages external && bunx tsc --emitDeclarationOnly"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "twitter-openapi-typescript": "^0.0.55",
    "twitter-openapi-typescript-generated": "^0.0.38"
  }
}
