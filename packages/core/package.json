  "license": "MIT",
  "author": "yutakobayashidev",
  "repository": {
    "type": "git",
    "url": "https://github.com/yutakobayashidev/xnotif"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
